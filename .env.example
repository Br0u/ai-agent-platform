# 复制为.env后再部署；不要提交真实密钥。
POSTGRES_DB=ai_agent_platform
POSTGRES_USER=ai_agent_owner
POSTGRES_PASSWORD=replace-with-a-long-random-url-safe-secret
MIGRATOR_DATABASE_PASSWORD=replace-with-an-independent-migrator-secret
RUNTIME_DATABASE_PASSWORD=replace-with-an-independent-runtime-secret
BACKUP_DATABASE_PASSWORD=replace-with-an-independent-backup-secret
AGNO_MIGRATOR_DATABASE_PASSWORD=replace-with-an-independent-agno-migrator-secret
AGNO_DATABASE_PASSWORD=replace-with-an-independent-agno-runtime-secret
MIGRATOR_DATABASE_URL=postgresql://ai_agent_migrator:replace-with-an-independent-migrator-secret@db:5432/ai_agent_platform
RUNTIME_DATABASE_URL=postgresql://ai_agent_runtime:replace-with-an-independent-runtime-secret@db:5432/ai_agent_platform
BACKUP_DATABASE_URL=postgresql://ai_agent_backup:replace-with-an-independent-backup-secret@db:5432/ai_agent_platform
AGNO_MIGRATOR_DATABASE_URL=postgresql+psycopg_async://ai_agent_agno_migrator:replace-with-an-independent-agno-migrator-secret@db:5432/ai_agent_platform
AGNO_DATABASE_URL=postgresql+psycopg_async://ai_agent_agno:replace-with-an-independent-agno-runtime-secret@db:5432/ai_agent_platform
OS_SECURITY_KEY=replace-with-an-independent-internal-agentos-security-key
# Compose reads credentials from ignored, chmod 600 files. These paths may be absolute.
POSTGRES_PASSWORD_FILE=.secrets/postgres_password
MIGRATOR_DATABASE_PASSWORD_FILE=.secrets/migrator_database_password
RUNTIME_DATABASE_PASSWORD_FILE=.secrets/runtime_database_password
BACKUP_DATABASE_PASSWORD_FILE=.secrets/backup_database_password
# Exactly one non-whitespace line, at least 32 bytes; chmod 600 and never commit it.
BACKUP_ENCRYPTION_KEY_FILE=.secrets/backup_encryption_key
AGNO_MIGRATOR_DATABASE_PASSWORD_FILE=.secrets/agno_migrator_database_password
AGNO_DATABASE_PASSWORD_FILE=.secrets/agno_database_password
MIGRATOR_DATABASE_URL_FILE=.secrets/migrator_database_url
RUNTIME_DATABASE_URL_FILE=.secrets/runtime_database_url
AGNO_MIGRATOR_DATABASE_URL_FILE=.secrets/agno_migrator_database_url
AGNO_DATABASE_URL_FILE=.secrets/agno_database_url
BETTER_AUTH_SECRET_FILE=.secrets/better_auth_secret
OS_SECURITY_KEY_FILE=.secrets/os_security_key
# Task 6 will wire this ignored secret file into Compose. Runtime settings
# currently require ASSISTANT_SESSION_SECRET directly.
ASSISTANT_SESSION_SECRET_FILE=.secrets/assistant_session_secret
# Local migration commands use DATABASE_URL; production web receives RUNTIME_DATABASE_URL through Compose.
DATABASE_URL=postgresql://ai_agent_migrator:replace-with-an-independent-migrator-secret@db:5432/ai_agent_platform
TEST_DATABASE_URL=postgresql://ai_agent_test:replace-with-a-test-only-secret@127.0.0.1:5432/ai_agent_platform_test

# Production: generate at least 32 random characters and use the externally reachable HTTPS URL.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://127.0.0.1:8080
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:8080
# Exact external origin only: no path, credentials, query, fragment, or trailing slash.
# Plain HTTP is accepted only for localhost, 127.0.0.1, or [::1] development origins.
ASSISTANT_PUBLIC_ORIGIN=http://127.0.0.1:8080
# Generate at least 32 random bytes; this committed value is a non-secret placeholder.
ASSISTANT_SESSION_SECRET=replace-with-at-least-32-random-secret-bytes

HTTP_PORT=8080
# Required: use the externally visible DNS hostname in production. Do not include a scheme or port.
PUBLIC_HOST=127.0.0.1
# Local acceptance only. Keep false in production, including when PUBLIC_HOST is a DNS name.
ALLOW_LOCAL_VALIDATION_HOSTS=false
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
FEATURE_EMAIL_VERIFICATION=false
