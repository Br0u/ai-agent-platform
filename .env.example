# 复制为.env后再部署；不要提交真实密钥。
POSTGRES_DB=ai_agent_platform
POSTGRES_USER=ai_agent_owner
POSTGRES_PASSWORD=replace-with-a-long-random-url-safe-secret
MIGRATOR_DATABASE_PASSWORD=replace-with-an-independent-migrator-secret
RUNTIME_DATABASE_PASSWORD=replace-with-an-independent-runtime-secret
BACKUP_DATABASE_PASSWORD=replace-with-an-independent-backup-secret
MIGRATOR_DATABASE_URL=postgresql://ai_agent_migrator:replace-with-an-independent-migrator-secret@db:5432/ai_agent_platform
RUNTIME_DATABASE_URL=postgresql://ai_agent_runtime:replace-with-an-independent-runtime-secret@db:5432/ai_agent_platform
BACKUP_DATABASE_URL=postgresql://ai_agent_backup:replace-with-an-independent-backup-secret@db:5432/ai_agent_platform
# Local migration commands use DATABASE_URL; production web receives RUNTIME_DATABASE_URL through Compose.
DATABASE_URL=postgresql://ai_agent_migrator:replace-with-an-independent-migrator-secret@db:5432/ai_agent_platform
TEST_DATABASE_URL=postgresql://ai_agent_test:replace-with-a-test-only-secret@127.0.0.1:5432/ai_agent_platform_test

# Production: generate at least 32 random characters and use the externally reachable HTTPS URL.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://127.0.0.1:8080
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:8080

HTTP_PORT=8080
# Required: use the externally visible DNS hostname in production. Do not include a scheme or port.
PUBLIC_HOST=127.0.0.1
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
FEATURE_EMAIL_VERIFICATION=false
