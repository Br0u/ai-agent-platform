                },
                "children": [
                  {
                    "type": "text",
                    "value": "AGENT_ENABLED=true\nASSISTANT_PROVIDER_MODE=agentos\n"
                  }
                ]
              }
            ]
          },
          {
            "type": "element",
            "tagName": "p",
            "properties": {},
            "children": [
              {
                "type": "element",
                "tagName": "code",
                "properties": {},
                "children": [
                  {
                    "type": "text",
                    "value": "AGENT_ENABLED=false"
                  }
                ]
              },
              {
                "type": "text",
                "value": " 是紧急 kill switch：Agent 不注册可运行的码多多，后台控制面只读且 mutation 返回固定不可用错误。"
              },
              {
                "type": "element",
                "tagName": "code",
                "properties": {},
                "children": [
                  {
                    "type": "text",
                    "value": "ASSISTANT_PROVIDER_MODE=placeholder"
                  }
                ]
              },
              {
                "type": "text",
                "value": " 让 Web 保持安全占位响应。"
              }
            ]
          },
          {
            "type": "element",
            "tagName": "h3",
            "properties": {
              "id": "doc-content-启动服务并检查健康状态"
            },
            "children": [
              {
                "type": "text",
                "value": "启动服务并检查健康状态"
