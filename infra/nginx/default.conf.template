map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

map $request_method $auth_post_method {
  default "";
  POST $binary_remote_addr;
}

map $auth_post_method $auth_post_key {
  default $auth_post_method;
}

map $host $configured_public_host_allowed {
  default 0;
  "${PUBLIC_HOST}" 1;
}

map $host $loopback_host_allowed {
  default 0;
  localhost 1;
  127.0.0.1 1;
  ~^\[?::1\]?$ 1;
}

map "$configured_public_host_allowed:$loopback_host_allowed" $host_allowed {
  default 0;
  ~^1: 1;
  ~:1$ 1;
}

limit_req_zone $auth_post_key zone=auth_post_per_ip:10m rate=5r/m;

upstream web_upstream {
  server web:3000;
  keepalive 32;
}

server {
  listen 8080;
  server_name _;

  if ($host_allowed = 0) {
    return 421;
  }

  add_header X-Content-Type-Options nosniff always;
  add_header X-Frame-Options SAMEORIGIN always;
  add_header Referrer-Policy strict-origin-when-cross-origin always;

  location ~ ^/(?:login|register|staff/login|staff/two-factor|staff/re-auth)$ {
    limit_req zone=auth_post_per_ip burst=5 nodelay;
    limit_req_status 429;
    add_header X-Auth-Rate-Limit $limit_req_status always;
    proxy_http_version 1.1;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://web_upstream;
  }

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_pass http://web_upstream;
  }
}
