map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

map $request_method $auth_post_method {
  default "";
  POST $binary_remote_addr;
}

map $auth_post_method $auth_post_key {
  default $auth_post_method;
}

map $request_method $public_api_post_key {
  default "";
  POST $binary_remote_addr;
}

map $host $configured_public_host_allowed {
  default 0;
  "${PUBLIC_HOST}" 1;
}

map $host $loopback_host_allowed {
  default 0;
  localhost 1;
  127.0.0.1 1;
  ~^\[?::1\]?$ 1;
}

map "${ALLOW_LOCAL_VALIDATION_HOSTS}:$loopback_host_allowed" $local_validation_host_allowed {
  default 0;
  ~^true:1$ 1;
}

map "$configured_public_host_allowed:$local_validation_host_allowed" $host_allowed {
  default 0;
  ~^1: 1;
  ~:1$ 1;
}

limit_req_zone $auth_post_key zone=auth_post_per_ip:10m rate=5r/m;
limit_req_zone $public_api_post_key zone=pricing_estimate_per_ip:10m rate=10r/m;
limit_req_zone $public_api_post_key zone=assistant_chat_per_ip:10m rate=30r/m;

upstream web_upstream {
  server web:3000;
  keepalive 32;
}

server {
  listen 8080;
  server_name _;

  if ($host_allowed = 0) {
    return 421;
  }

  add_header X-Content-Type-Options nosniff always;
  add_header X-Frame-Options SAMEORIGIN always;
  add_header Referrer-Policy strict-origin-when-cross-origin always;

  location ~ ^/(?:login|register|staff/login|staff/two-factor|staff/re-auth)$ {
    limit_req zone=auth_post_per_ip burst=5 nodelay;
    limit_req_status 429;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header X-Auth-Rate-Limit $limit_req_status always;
    proxy_http_version 1.1;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://web_upstream;
  }

  location = /api/v1/pricing/estimate {
    limit_req zone=pricing_estimate_per_ip burst=5 nodelay;
    limit_req_status 429;
    error_page 429 = @public_api_rate_limited;
    proxy_http_version 1.1;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://web_upstream;
  }

  location = /api/v1/assistant/chat {
    limit_req zone=assistant_chat_per_ip burst=10 nodelay;
    limit_req_status 429;
    error_page 429 = @public_api_rate_limited;
    proxy_http_version 1.1;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering off;
    proxy_cache off;
    proxy_pass http://web_upstream;
  }

  location @public_api_rate_limited {
    default_type application/json;
    add_header Cache-Control "no-store" always;
    add_header Retry-After "60" always;
    return 429 '{"version":"1","requestId":"$request_id","error":{"code":"rate_limited","message":"请求过于频繁，请稍后再试。","retryable":true}}';
  }

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $http_host;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_pass http://web_upstream;
  }
}
